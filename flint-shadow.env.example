# Copy to .env.flint-shadow for local shadow runs. Do not commit real keys.

# Choose one provider supported by TradingAgents:
# openai, google, anthropic, xai, deepseek, qwen, glm, openrouter, ollama, azure
TRADINGAGENTS_LLM_PROVIDER=ollama
TRADINGAGENTS_DEEP_MODEL=llama3:latest
TRADINGAGENTS_QUICK_MODEL=llama3:latest

# Optional provider credentials. Leave blank for local Ollama.
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=
# XAI_API_KEY=
# DEEPSEEK_API_KEY=
# DASHSCOPE_API_KEY=
# ZHIPU_API_KEY=
# OPENROUTER_API_KEY=
# ALPHA_VANTAGE_API_KEY=
